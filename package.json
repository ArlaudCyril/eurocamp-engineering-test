{
  "name": "eurocamp",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "lint": "nx run-many --target=lint --all",
    "start:all": "docker-compose up",
    "start:deps": "docker-compose up eurocamp-db eurocamp-api",
    "start:api": "nx run engineering:serve",
    "seed:run": "nx run engineering:seedrun",
    "test:api": "nx run engineering:test",
    "test:api:watch": "nx run engineering:test --watch",
    "client:test": "jest --config client/jest.config.js --runInBand",
    "client:check": "tsc --project client/tsconfig.json --noEmit",
    "client:demo": "ts-node --project client/tsconfig.json client/src/demo.ts",
    "frontend:dev": "vite --config frontend/vite.config.ts",
    "frontend:build": "vite build --config frontend/vite.config.ts",
    "frontend:preview": "vite preview --config frontend/vite.config.ts",
    "frontend:check": "tsc --project frontend/tsconfig.json --noEmit",
    "frontend:test": "jest --config frontend/jest.config.js --runInBand",
    "typeorm-build-config": "tsc apps/engineering/typeorm.config.ts --outDir ./dist",
    "typeorm-generate-migrations": "npm run typeorm-build-config && typeorm -d dist/typeorm.config.js migration:generate",
    "typeorm-run-migrations": "npm run typeorm-build-config && typeorm -d dist/typeorm.config.js migration:run"
  },
  "private": true,
  "dependencies": {
    "@nestjs/common": "^9.0.0",
    "@nestjs/config": "^2.3.1",
    "@nestjs/core": "^9.0.0",
    "@nestjs/platform-express": "^9.0.0",
    "@nestjs/swagger": "^6.2.1",
    "@nestjs/typeorm": "^9.0.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "axios": "^1.3.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "faker": "^6.6.6",
    "helmet": "^6.0.1",
    "lucide-react": "^0.468.0",
    "pg": "^8.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^4.6.1",
    "tailwind-merge": "^2.5.5",
    "typeorm": "0.3.12",
    "typeorm-seeding": "^1.6.1",
    "uuid": "^9.0.0",
    "uuidv4": "^6.2.13",
    "vite": "^4.5.5"
  },
  "devDependencies": {
    "@nestjs/schematics": "^9.0.0",
    "@nestjs/testing": "^9.0.0",
    "@nrwl/eslint-plugin-nx": "15.7.2",
    "@nrwl/jest": "15.7.2",
    "@nrwl/linter": "15.7.2",
    "@nrwl/nest": "15.7.2",
    "@nrwl/node": "15.7.2",
    "@nrwl/nx-cloud": "latest",
    "@nrwl/webpack": "15.7.2",
    "@nrwl/workspace": "15.7.2",
    "@types/faker": "^6.6.9",
    "@types/jest": "28.1.1",
    "@types/node": "18.7.1",
    "@typescript-eslint/eslint-plugin": "^5.36.1",
    "@typescript-eslint/parser": "^5.36.1",
    "autoprefixer": "^10.4.20",
    "eslint": "~8.15.0",
    "eslint-config-prettier": "8.1.0",
    "jest": "28.1.1",
    "jest-environment-jsdom": "28.1.1",
    "nx": "15.7.2",
    "postcss": "^8.4.49",
    "prettier": "^2.6.2",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "28.0.5",
    "ts-node": "10.9.1",
    "tslib": "^2.5.0",
    "typescript": "~4.8.2"
  }
}
